{
  "name": "telemetry",
  "version": "1.0.0",
  "description": "A professional, privacy-first, open-source web analytics platform. Cookieless by design, fully GDPR/CCPA compliant, and weighing in at under 1KB.",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc && mkdir -p dist/generated && cp -r src/generated/prisma dist/generated/prisma",
    "start": "node dist/server.js"
  },
  "keywords": [
    "telemetry",
    "analytics",
    "web-analytics",
    "privacy",
    "privacy-first",
    "cookieless",
    "gdpr",
    "ccpa",
    "fastify",
    "prisma",
    "postgresql"
  ],
  "author": "Atharv Dange <atharvdange618@gmail.com> (https://github.com/atharvdange618)",
  "license": "MIT",
  "homepage": "https://usetelemetry.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atharvdange618/Telemetry.git"
  },
  "bugs": {
    "url": "https://github.com/atharvdange618/Telemetry/issues"
  },
  "type": "commonjs",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/oauth2": "^8.1.2",
    "@fastify/static": "^8.2.0",
    "@prisma/client": "^6.13.0",
    "chalk": "^5.4.1",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.1",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^5.0.2",
    "prisma": "^6.13.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "pino-pretty": "^13.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "allowScripts": {
    "@prisma/client@6.13.0": true,
    "@prisma/engines@6.13.0": true,
    "esbuild@0.25.8": true,
    "prisma@6.13.0": true
  }
}
